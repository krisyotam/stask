.TH STASK 1 "2026-03-21" "stask 0.2" "Simple Task Manager"
.SH NAME
stask \- simple task manager with markdown documents
.SH SYNOPSIS
.B stask
.RB [ \-ghv ]
.br
.B stask
.RB [ ls ]
.br
.B stask
.B new
.I list
.br
.B stask
.B rm
.I list
.br
.B stask
.I list
.br
.B stask
.I list
.B add
.I \(dqtext\(dq
.br
.B stask
.I list
.B done
.I id
.br
.B stask
.I list
.B undo
.I id
.br
.B stask
.I list
.B del
.I id
.br
.B stask
